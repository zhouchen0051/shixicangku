# 用于计算班次任务完成情况的程序

def calculate_shift_report():
    print("===== Расчет выполнения сменного задания =====")

    # 向用户请求数据
    product_name = input("Введите название продукта: ")
    plan = float(input("Введите плановое задание на смену (в тоннах): "))
    fact = float(input("Введите фактически произведенное количество (в тоннах): "))

    # 计算完成百分比
    percent = (fact / plan) * 100

    # 确定结果
    if percent >= 100:
        result_message = f"План выполнен ({percent:.2f}%)"
        result_status = "Выполнен"
    else:
        result_message = f"План не выполнен ({percent:.2f}%)"
        result_status = "Не выполнен"

    # 在屏幕上输出结果
    print(f"\nРезультат: {result_message}")

    # 将结果写入文件
    with open("shift_results.txt", "a", encoding="utf-8") as file:
        file.write(f"{product_name} | План: {plan} т | Факт: {fact} т | "
                   f"Выполнение: {percent:.2f}% | Статус: {result_status}\n")

    print("Результат сохранен в файл shift_results.txt")

# 运行程序
if __name__ == "__main__":
    calculate_shift_report()
